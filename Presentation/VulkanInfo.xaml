<Window x:Class="Presentation.VulkanInfo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        Width="400"
        Height="450">
    <Grid>
        <Border CornerRadius="30" Background="Gray" BorderBrush="Orange" BorderThickness="5">
            <Grid>
                

                <Image Source="/Resources/volcano.png" Opacity="0.3"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="5*" />
                    </Grid.RowDefinitions>
                    <TextBox Text="NazivVulkana"
                               x:Name="NazivVulkana"
                               FontSize="26"
                               FontWeight="Bold"
                             HorizontalContentAlignment="Center"
                             Width="230"
                               Margin="6"
                               Grid.Row="0"
                                Background="Transparent"
                             BorderBrush="Transparent"/>
                    <TextBlock Text="NazivVulkana"
                           x:Name="NazivVulkanaText"
                           FontSize="26"
                           FontWeight="Bold"
                         Width="230"
                           Margin="6"
                           Grid.Row="0"
                            Background="Transparent"
                               TextAlignment="Center"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="Orange"
                                Grid.Column="0"
                                BorderThickness="3"
                                CornerRadius="25"
                                Width="130" Height="130"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="White"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="SlikaVulkana" Stretch="Fill" Source="/Resources/randomTestLogo.jpg" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="25" RadiusY="25" Rect="0,0,125,125"/>
                                    </Image.Clip>
                                    </Image>
                                    <Button Background="Transparent"
                                        Click="PromeniSliku"
                                        x:Name="PromenaSlikeButton"
                                        BorderBrush="Transparent"
                                        Cursor="Hand"/>
                            </Grid>
                        </Border>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.2*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="0.5*" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Drzava: "
                                             FontSize="20"
                                               Margin="0 0 2 1"
                                              VerticalAlignment="Bottom"
                                              Grid.Row="0"
                                            Background="Transparent"
                                           x:Name="DrzavaText"/>
                                <TextBox Text="Kambodza"
                                       x:Name="DrzavaVulkana"
                                       FontSize="20"
                                        Margin="0 0 15 0"
                                       VerticalContentAlignment="Bottom"
                                         Grid.Column="1"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                         Width="150"/>
                                </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Visina:  "
                                         FontSize="20"
                                           Margin="2 0 2 1"
                                          VerticalAlignment="Center"
                                          Grid.Row="0"
                                        Background="Transparent"
                                           x:Name="VisinaText"/>
                                <TextBox Text="2056m"
                                       x:Name="VisinaVulkana"
                                       FontSize="20"
                                       VerticalContentAlignment="Center"
                                       Grid.Column="1"
                                        Margin="0 0 15 0"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                         Width="150"/>
                                </Grid>
                            <TextBlock Text="15.16.1234 23:45"
                                       x:Name="DatumDodavanja"
                                       FontSize="20"
                                       VerticalAlignment="Top"
                                       Grid.Row="3"
                                        Margin="0 0 15 0"
                                     Background="Transparent"/>

                            <Button Content="Sacuvajte izmene"
                                    x:Name="IzmeniSacuvajVulkanButton"
                                    Grid.Row="4"
                                    Height="25"
                                    Width="110"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="2 0 0 0"
                                    Background="LightGreen"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    BorderBrush="Orange"
                                    BorderThickness="2"
                                    Click="SacuvajVulkan"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="7"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                        </Grid>
                    </Grid>
                    <Border BorderBrush="Orange"
                            Grid.Column="0"
                            BorderThickness="3"
                            CornerRadius="5 5 15 15"
                            Padding="2"
                            Grid.Row="3"
                            Background="White"
                            Margin="15 5 15 15">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ToolBar x:Name="RTFTextEditing" Grid.Row="0" Margin="3 2 3 2">
                                <ToggleButton Name="BoldBtn" Click="BoldBtn_Click" FontWeight="Bold" Width="30">
                                    B
                                </ToggleButton>

                                <ToggleButton Name="ItalicBtn" Click="ItalicBtn_Click" FontStyle="Italic" Width="30">
                                    I
                                </ToggleButton>

                                <ToggleButton Name="UnderlineBtn" Click="UnderlineBtn_Click" Width="30">
                                    U
                                </ToggleButton>

                                <Separator/>

                                <ComboBox Name="FontCombo" Width="180" SelectionChanged="FontCombo_SelectionChanged"/>

                                <ComboBox Name="FontSizeCombo" Width="60" SelectionChanged="FontSizeCombo_SelectionChanged">
                                    <ComboBoxItem Content="10"/>
                                    <ComboBoxItem Content="12"/>
                                    <ComboBoxItem Content="14"/>
                                    <ComboBoxItem Content="18"/>
                                    <ComboBoxItem Content="24"/>
                                    <ComboBoxItem Content="32"/>
                                </ComboBox>
                                <Separator/>
                                <ComboBox Name="ColorCombo" Width="150" SelectionChanged="ColorCombo_SelectionChanged"/>
                            </ToolBar>
                            <RichTextBox x:Name="RTFField"
                                         Grid.Row="1"
                             Margin="3"
                             BorderBrush="Transparent"
                             SelectionChanged="RTFField_SelectionChanged"/>
                        </Grid>
                    </Border>
                </Grid>
                <Button Content="X"
    Grid.Row="1"
    Width="30"
    Height="30"
    HorizontalAlignment="Right"
    VerticalAlignment="Top"
    Margin="0,10,10,0"
    Background="Transparent"
    Foreground="White"
    FontWeight="Bold"
    BorderBrush="Orange"
    BorderThickness="2"
    Click="Close_Click"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10"
    Background="{TemplateBinding Background}"
    BorderBrush="{TemplateBinding BorderBrush}"
    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
        </Border>
    </Grid>
</Window>

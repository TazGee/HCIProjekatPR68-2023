<Window x:Class="Presentation.ListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation"
        mc:Ignorable="d"
        Title="Lista vulkana" Height="500" Width="800"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        ResizeMode="CanResize"
        MinWidth="600"
        MinHeight="400">
    <Grid>
        <Border CornerRadius="30" Background="Gray" BorderBrush="Orange" BorderThickness="5">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border CornerRadius="20 20 5 5" 
                    Grid.Row="0"
                    Background="Orange" 
                    BorderBrush="Orange" 
                    BorderThickness="5"
                    VerticalAlignment="Top"
                    Height="50"
                    Margin="13 13 13 5">

                    <Grid>
                        <Button Content="X"
    Grid.Row="1"
    Width="30"
    Height="30"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    Margin="3,3,7,3"
    Background="Gray"
    Foreground="White"
    FontWeight="Bold"
    BorderBrush="DarkOrange"
    BorderThickness="2"
    Click="Close_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="10"
    Background="{TemplateBinding Background}"
    BorderBrush="{TemplateBinding BorderBrush}"
    BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid Margin="5 0 0 0" Grid.Column="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border BorderBrush="Black"
                                        Grid.Column="0"
                                        BorderThickness="1"
                                        CornerRadius="30"
                                        Padding="2"
                                        Width="35" Height="35">
                                    <Image Source="/Resources/avatar.png" Width="30" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <Button Grid.Column="1"
                                        Content="UnknownUsername"
                                        x:Name="UsernameButton"
                                        FontWeight="Bold"
                                        FontSize="15"
                                        Width="Auto"
                                        Height="Auto"
                                        Padding="4"
                                        Margin="5 0 0 0"
                                        VerticalAlignment="Center"
                                        BorderThickness="0" 
                                        BorderBrush="Transparent"
                                        Background="Transparent"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="9"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.2"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                            </Grid>
                            <Grid x:Name="AdminPanelGrid" Grid.Column="1" Margin=" 15 0 0 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Content="+ Dodaj vulkan"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Width="Auto"
                                        Height="Auto"
                                        Padding="8"
                                        VerticalAlignment="Center"
                                        BorderThickness="2" 
                                        BorderBrush="DarkOrange"
                                        Background="LightGreen"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="13"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                
                                <Button Grid.Column="1"
                                        Content="- Obrisi izabrane"
                                        FontWeight="Bold"
                                        FontSize="13"
                                        Width="Auto"
                                        Height="Auto"
                                        Padding="8"
                                        VerticalAlignment="Center"
                                        BorderThickness="2" 
                                        BorderBrush="DarkOrange"
                                        Background="IndianRed"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Margin="7 0 0 0">
                                    <Button.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="13"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
                
                
                <Border CornerRadius="5 5 20 20" 
                        Grid.Row="1"
                        Background="Orange" 
                        BorderBrush="Orange" 
                        BorderThickness="5"
                        Margin="13 5 13 13">
                    
                    
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

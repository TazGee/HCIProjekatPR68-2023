<Window x:Class="Presentation.DodajVulkan"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation"
        mc:Ignorable="d"
                WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        Width="400"
        Height="480">
    <Grid>
        <Border CornerRadius="30" Background="Gray" BorderBrush="Orange" BorderThickness="5">
            <Grid>
                <Button Content="X"
                    Grid.Row="1"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Background="Transparent"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderBrush="Orange"
                    BorderThickness="2"
                    Click="Close_Click"
                    Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="10"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Image Source="/Resources/volcano.png" Opacity="0.3"/>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="2.3*" />
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Dodavanje vulkana"
                               FontSize="30"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0 12 0 0"/>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="Orange"
                                Grid.Column="0"
                                BorderThickness="3"
                                CornerRadius="25"
                                Width="130" Height="130"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Background="White">
                            <Grid>
                                <Image Stretch="UniformToFill" x:Name="SlikaVulkana" Source="/Resources/volcano.png" Width="125" Height="125" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image.Clip>
                                        <RectangleGeometry RadiusX="25" RadiusY="25" Rect="0,0,125,125"/>
                                    </Image.Clip>
                                </Image>
                                <Button Background="Transparent"
                                        Click="PromeniSliku"
                                        x:Name="PromenaSlikeButton"
                                        BorderBrush="Transparent"
                                        Cursor="Hand">
                                    <TextBlock TextAlignment="Center" FontWeight="Bold" FontSize="13">
                                        Pritisni za
                                        <LineBreak/>
                                        promenu slike...
                                    </TextBlock>
                                </Button>
                            </Grid>
                        </Border>
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                                <TextBlock Text="Naziv vulkana"
                                   FontSize="13"
                                   Margin="0,0,0,2"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                                <TextBox x:Name="NazivVulkana" Width="180" Height="27" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="13"/>
                                        </Style>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                                <TextBlock Text="Drzava"
                                           FontSize="13"
                                           Margin="0,0,0,2"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBox x:Name="Drzava" Width="180" Height="27" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="13"/>
                                        </Style>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                            <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                                <TextBlock Text="Visina vulkana"
                                           FontSize="13"
                                           Margin="0,0,0,2"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBox x:Name="Visina" Width="180" Height="27" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                    <TextBox.Resources>
                                        <Style TargetType="{x:Type Border}">
                                            <Setter Property="CornerRadius" Value="13"/>
                                        </Style>
                                    </TextBox.Resources>
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </StackPanel>
                        </Grid>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Unesite opis vulkana..." TextAlignment="Center" FontSize="12" FontWeight="Bold" Margin="5" />
                        <ToolBar Grid.Row="1" Margin="15 2 15 2">
                            <ToggleButton Name="BoldBtn" Click="BoldBtn_Click" FontWeight="Bold" Width="30">
                                B
                            </ToggleButton>

                            <ToggleButton Name="ItalicBtn" Click="ItalicBtn_Click" FontStyle="Italic" Width="30">
                                I
                            </ToggleButton>

                            <ToggleButton Name="UnderlineBtn" Click="UnderlineBtn_Click" Width="30">
                                U
                            </ToggleButton>

                            <Separator/>

                            <ComboBox Name="FontCombo" Width="180" SelectionChanged="FontCombo_SelectionChanged"/>

                            <ComboBox Name="FontSizeCombo" Width="60" SelectionChanged="FontSizeCombo_SelectionChanged">
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="24"/>
                                <ComboBoxItem Content="32"/>
                            </ComboBox>
                            <Separator/>
                            <ComboBox Name="ColorCombo" Width="150" SelectionChanged="ColorCombo_SelectionChanged"/>
                        </ToolBar>
                        <RichTextBox x:Name="RTFField" Grid.Row="2" Margin="15 0 15 15" SelectionChanged="RTFField_SelectionChanged"/>
                    </Grid>
                    <Button Grid.Row="5"
                            Content="Dodaj vulkan"
                            FontWeight="Bold"
                            FontSize="13"
                            Width="150"
                            Height="35"
                            Margin="0,10"
                            HorizontalAlignment="Center"
                            BorderThickness="2" 
                            BorderBrush="Orange"
                            x:Name="DodajVulkanButton"
                            Click="AddVulkan"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="13"/>
                            </Style>
                        </Button.Resources>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>

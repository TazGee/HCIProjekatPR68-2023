<Window x:Class="Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Presentation"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="30" Background="Gray" BorderBrush="Orange" BorderThickness="5">
        <Grid>
            <Button Content="X"
                    Grid.Row="1"
                    Width="30"
                    Height="30"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,10,10,0"
                    Background="Transparent"
                    Foreground="White"
                    FontWeight="Bold"
                    BorderBrush="Orange"
                    BorderThickness="2"
                    Click="Close_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Grid x:Name="PrijavaGrid" Visibility="Hidden">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0.3*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="1"
               Text="Prijava"
               FontSize="40"
               FontWeight="Bold"
               HorizontalAlignment="Center"
               Margin="0 12 0 0"/>

            <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Text="Username"
                   FontSize="13"
                   Margin="0,0,0,5"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
                <TextBox Width="250" Height="30" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="13"/>
                        </Style>
                    </TextBox.Resources>
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>

            <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,10">
                <TextBlock Text="Password"
                   FontSize="13"
                   Margin="0,0,0,5"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
                <PasswordBox Width="250" Height="30" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                    <PasswordBox.Template>
                        <ControlTemplate TargetType="PasswordBox">
                            <Border CornerRadius="13"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                            </Border>
                        </ControlTemplate>
                    </PasswordBox.Template>
                    <PasswordBox.Style>
                        <Style TargetType="PasswordBox">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </PasswordBox.Style>
                </PasswordBox>
            </StackPanel>

            <Button Grid.Row="5"
            Content="Prijavi se"
            FontWeight="Bold"
            FontSize="13"
            Width="150"
            Height="35"
            Margin="0,10"
            HorizontalAlignment="Center"
            BorderThickness="2" 
            BorderBrush="Orange"
            x:Name="PrijavaButton"
            Click="PrijavaClick">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="13"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Button Grid.Row="6"
            Content="Registruj se"
            FontSize="10"
            Width="100"
            Height="28"
            Margin="0,5"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            BorderThickness="2" 
            BorderBrush="Orange">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="13"/>
                    </Style>
                </Button.Resources>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
            <Grid x:Name="RegistracijaGrid" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0.3*" />
                </Grid.RowDefinitions>

                
                <TextBlock Grid.Row="1"
                           Text="Registracija"
                           FontSize="40"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0 12 0 0"/>

                <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock Text="Username"
                               FontSize="13"
                               Margin="0,0,0,5"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBox Width="250" Height="30" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="CornerRadius" Value="13"/>
                            </Style>
                        </TextBox.Resources>
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <StackPanel Grid.Row="3" HorizontalAlignment="Center" Margin="0,10">
                    <TextBlock Text="Password"
                               FontSize="13"
                               Margin="0,0,0,5"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <PasswordBox Width="250" Height="30" FontWeight="Bold" FontSize="13" BorderThickness="2" BorderBrush="Orange" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <PasswordBox.Template>
                            <ControlTemplate TargetType="PasswordBox">
                                <Border CornerRadius="13"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="5"/>
                                </Border>
                            </ControlTemplate>
                        </PasswordBox.Template>
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.7"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>
                </StackPanel>

                <CheckBox Content="Da li ste administrator?"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Grid.Row="4"
                          FontSize="13">

                    <CheckBox.Style>
                        <Style TargetType="CheckBox">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="CheckBox">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                            <!-- Kutijica -->
                                            <Border x:Name="box"
                                    Width="20"
                                    Height="20"
                                    CornerRadius="6"
                                    BorderBrush="Orange"
                                    BorderThickness="2"
                                    Background="Transparent"
                                    VerticalAlignment="Center">

                                                <!-- Check mark -->
                                                <Grid>
                                                    <Path x:Name="check"
                                          Data="M 4 10 L 8 14 L 16 6"
                                          Stroke="White"
                                          StrokeThickness="2"
                                          Visibility="Collapsed"/>
                                                </Grid>
                                            </Border>

                                            <!-- Tekst -->
                                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <ControlTemplate.Triggers>

                                            <!-- Checked -->
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="box" Property="Background" Value="Orange"/>
                                                <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                            </Trigger>

                                            <!-- Hover -->
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="box" Property="Background" Value="#33FFA500"/>
                                            </Trigger>

                                            <!-- Disabled -->
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="box" Property="Opacity" Value="0.5"/>
                                            </Trigger>

                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </CheckBox.Style>

                </CheckBox>

                <Button Grid.Row="5"
                        Content="Registruj se"
                        FontWeight="Bold"
                        FontSize="13"
                        Width="150"
                        Height="35"
                        Margin="0,10"
                        HorizontalAlignment="Center"
                        BorderThickness="2" 
                        BorderBrush="Orange"
                        x:Name="RegistracijaButton"
                        Click="RegistracijaClick">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="13"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Row="6"
                        Content="Prijavi se"
                        FontSize="10"
                        Width="100"
                        Height="28"
                        Margin="0,5"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        BorderThickness="2" 
                        BorderBrush="Orange">
                    <Button.Resources>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="CornerRadius" Value="13"/>
                        </Style>
                    </Button.Resources>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
